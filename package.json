{
  "name": "agent-locks",
  "version": "0.1.0",
  "description": "Filesystem-based, database-free work-claiming and coordination locks for AI coding agents (Claude Code and friends) working across multiple git worktrees of the same repository, exposed as an MCP stdio server.",
  "type": "module",
  "license": "MIT",
  "author": "andysfruit021209@gmail.com",
  "bin": {
    "agent-locks": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "pretest": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "gray-matter": "^4.0.3",
    "minimatch": "^10.0.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "agents",
    "claude-code",
    "locks",
    "coordination",
    "worktree"
  ]
}
